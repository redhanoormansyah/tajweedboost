                  d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.06-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-.99 0-1.48.18-3.41 2.93-6.19 6.36-6.41.07 0 .15-.01.22-.01V11c-1.24.15-2.49.67-3.34 1.6-.88.97-1.31 2.3-1.14 3.59.13 1.25.8 2.39 1.7 3.2.99.88 2.32 1.34 3.63 1.25 1.77-.05 3.32-1.21 3.91-2.89.26-.74.33-1.53.33-2.31V.02z" />
