---
const { frontmatter } = Astro.props;
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{frontmatter.title} - Blog Tajweed Boost</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <link rel="apple-touch-icon" href="/images/favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <style is:global>
    .blog-container {
      max-width: 800px;
      margin: 140px auto 60px;
      padding: 0 24px;
      color: var(--ink);
      line-height: 1.8;
      font-size: 17px;
    }
    .blog-header {
      text-align: center;
      margin-bottom: 40px;
    }
    .blog-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(32px, 4vw, 48px);
      color: var(--ink);
      margin-bottom: 12px;
      line-height: 1.2;
    }
    .blog-meta {
      color: var(--ink-soft);
      font-size: 14px;
    }
    .blog-content h1, .blog-content h2, .blog-content h3 {
      font-family: 'Playfair Display', serif;
      color: var(--ink);
      margin-top: 40px;
      margin-bottom: 16px;
    }
    .blog-content p {
      margin-bottom: 20px;
      color: var(--ink-soft);
      font-weight: 300;
    }
    .blog-content a {
      color: var(--emerald);
      text-decoration: underline;
    }
    .blog-content blockquote {
      border-left: 4px solid var(--gold);
      padding-left: 20px;
      margin-left: 0;
      color: var(--ink-mid);
      font-style: italic;
      background: var(--gold-pale);
      padding: 16px 20px;
      border-radius: 0 12px 12px 0;
    }
    .blog-content ul, .blog-content ol {
      margin-bottom: 20px;
      padding-left: 20px;
      color: var(--ink-soft);
    }
    .blog-content li {
      margin-bottom: 8px;
    }
    .blog-content strong {
      color: var(--ink);
      font-weight: 600;
    }
    .blog-content img {
      max-width: 100%;
      border-radius: 12px;
      margin: 32px 0;
      box-shadow: var(--shadow);
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--ink-soft);
      margin-bottom: 24px;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s;
    }
    .back-link:hover {
      color: var(--gold);
    }
  </style>
</head>
<body>
  <!-- NAV -->
  <nav>
    <a href="/" class="logo"><img src="/images/logo tajweedboost ok.png" alt="Tajweed Boost"></a>
    <ul>
      <li><a href="/">Beranda</a></li>
      <li><a href="/blog" style="color: var(--gold);">Blog</a></li>
      <li><a href="/#kelas">Kelas</a></li>
      <li><a href="/#harga">Harga</a></li>
    </ul>
    <div class="menu-toggle">
      <span></span><span></span><span></span>
    </div>
  </nav>
  <div class="mobile-overlay"></div>

  <!-- ARTICLE CONTENT -->
  <main class="blog-container fade-in">
    <div class="blog-header">
      <a href="/blog" class="back-link">← Kembali ke Blog</a>
      <h1 class="blog-title">{frontmatter.title}</h1>
      <div class="blog-meta">
        Diterbitkan pada {new Date(frontmatter.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
      </div>
    </div>
    
    <div class="blog-content">
      <slot />
    </div>
  </main>

  <!-- FOOTER -->
  <footer style="margin-top: 80px;">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="logo"><img src="/images/logo tajweedboost ok.png" alt="Tajweed Boost"
            style="height: 80px; margin-bottom: 16px;"></a>
        <p>Platform tahsin online profesional dengan pengajar bersanad. Dari nol hingga fasih, dari rumahmu.</p>
      </div>
      <div class="footer-links">
        <h4>Program</h4>
        <ul>
          <li><a href="/#kelas">Kelas Talaqqi</a></li>
          <li><a href="/#kelas">Kelas Teori</a></li>
          <li><a href="/#harga">Kelas Private</a></li>
          <li><a href="/#harga">Paket Semester</a></li>
        </ul>
      </div>
      <div class="footer-links">
        <h4>Komunitas</h4>
        <ul class="social-icons">
          <li>
            <a href="https://instagram.com/tajweedboost" target="_blank" aria-label="Instagram">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
