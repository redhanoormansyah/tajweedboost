        </ul>
        <a href="https://goakal.com/tajweedboost" target="_blank" class="footer-goakal-link">Daftar via Goakal →</a>
      </div>
      <div class="footer-links">
        <h4>Info</h4>
        <ul>
          <li><a href="/#masalah">Tentang Kami</a></li>
          <li><a href="/#testimoni">Testimoni</a></li>
